<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.buscadocs.controller.SearchController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16" />
    </padding>
    <HBox spacing="10">
        <TextField fx:id="queryField" promptText="Buscar..." HBox.hgrow="ALWAYS" onAction="#performSearch" />
        <TextField fx:id="extensionFilter" promptText="Extensión (ej. pdf,docx)" prefWidth="200" />
        <DatePicker fx:id="dateFrom" promptText="Desde" />
        <DatePicker fx:id="dateTo" promptText="Hasta" />
        <Button text="Buscar" onAction="#performSearch" defaultButton="true" />
    </HBox>
    <Label fx:id="statusLabel" text="0 resultados" styleClass="status-label" />
    <ListView fx:id="resultsList" VBox.vgrow="ALWAYS" />
</VBox>